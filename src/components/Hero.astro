---
import type { ProfileData } from '../types';
interface Props { profile: ProfileData }
const { profile } = Astro.props;

const iconLinks = [
  { href: profile.links.github, label: 'GitHub', icon: 'github' },
  { href: profile.links.linkedin, label: 'LinkedIn', icon: 'linkedin' },
  { href: profile.links.inspirehep, label: 'InspireHEP', icon: 'inspire' },
  { href: profile.links.orcid, label: 'ORCID', icon: 'orcid' },
  { href: profile.links.twitter, label: 'Twitter', icon: 'twitter' },
  { href: profile.links.lattes, label: 'Lattes', icon: 'lattes' },
];
---

<section id="hero" class="min-h-screen flex flex-col justify-center px-6 pt-20 pb-12 max-w-5xl mx-auto">
  <div class="animate-fade-in">
    <p class="font-mono text-accent-400 text-sm mb-4 tracking-widest uppercase">
      Hello, world
    </p>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-50 leading-none mb-4">
      Lucas Torres<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-accent-400 to-indigo-400">
        Santana
      </span>
    </h1>
    <p class="text-xl md:text-2xl text-slate-400 font-light mt-6 max-w-2xl leading-relaxed">
      {profile.tagline}
    </p>

    <div class="flex flex-wrap items-center gap-3 mt-10">
      <a
        href="#about"
        class="px-5 py-2.5 rounded-lg bg-accent-600 hover:bg-accent-500 text-white font-medium text-sm transition-colors duration-200"
      >
        Learn more
      </a>
      <a
        href="#contact"
        class="px-5 py-2.5 rounded-lg border border-slate-700 hover:border-slate-500 text-slate-300 font-medium text-sm transition-colors duration-200"
      >
        Get in touch
      </a>
    </div>

    <div class="flex items-center gap-4 mt-10">
      {iconLinks.map(({ href, label, icon }) => (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={label}
          title={label}
          class="text-slate-500 hover:text-slate-200 transition-colors duration-200"
        >
          {icon === 'github' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
            </svg>
          )}
          {icon === 'linkedin' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          )}
          {icon === 'twitter' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
            </svg>
          )}
          {icon === 'inspire' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
          {icon === 'orcid' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 0 1-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.444h2.297c2.359 0 3.994-1.431 3.994-3.722 0-2.431-1.625-3.722-3.994-3.722h-2.297z"/>
            </svg>
          )}
          {icon === 'lattes' && (
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20 6H4c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-9 7H5v-2h6v2zm8 0h-2v2h-2v-2h-2v-2h2V9h2v2h2v2z"/>
            </svg>
          )}
        </a>
      ))}
    </div>
  </div>

  <div class="mt-20 text-slate-600 text-xs font-mono flex items-center gap-2">
    <span>scroll to explore</span>
    <svg class="w-3 h-3 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
