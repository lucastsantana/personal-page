---
import type { GithubRepo } from '../lib/github';

interface Props { repos: GithubRepo[]; githubUsername: string }
const { repos, githubUsername } = Astro.props;

const langColors: Record<string, string> = {
  TypeScript: 'text-blue-400',
  JavaScript: 'text-yellow-400',
  Python: 'text-green-400',
  Java: 'text-orange-400',
  'Jupyter Notebook': 'text-orange-300',
  C: 'text-purple-400',
  Rust: 'text-orange-500',
  Go: 'text-cyan-400',
};

function timeAgo(dateStr: string) {
  const d = new Date(dateStr);
  const now = new Date();
  const diff = Math.floor((now.getTime() - d.getTime()) / 1000);
  if (diff < 3600) return `${Math.floor(diff / 60)}m ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)}h ago`;
  if (diff < 2592000) return `${Math.floor(diff / 86400)}d ago`;
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}
---

<section id="projects" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="flex items-end justify-between mb-10">
    <h2 class="text-xs font-mono text-accent-400 uppercase tracking-widest">Projects</h2>
    <a
      href={`https://github.com/${githubUsername}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-slate-500 hover:text-slate-300 transition-colors font-mono"
    >
      View all on GitHub →
    </a>
  </div>

  {repos.length > 0 ? (
    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {repos.map((repo) => (
        <a
          href={repo.html_url}
          target="_blank"
          rel="noopener noreferrer"
          class="group p-5 rounded-xl bg-slate-900 border border-slate-800 hover:border-slate-600 transition-all duration-200 flex flex-col"
        >
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-mono text-sm font-medium text-slate-200 group-hover:text-accent-400 transition-colors break-all">
              {repo.name}
            </h3>
            <svg class="w-4 h-4 text-slate-600 group-hover:text-slate-400 transition-colors shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </div>
          <p class="text-xs text-slate-500 leading-relaxed flex-1 mb-4">
            {repo.description ?? 'No description provided.'}
          </p>
          <div class="flex items-center justify-between mt-auto">
            <div class="flex items-center gap-3">
              {repo.language && (
                <span class={`text-xs font-mono ${langColors[repo.language] ?? 'text-slate-400'}`}>
                  {repo.language}
                </span>
              )}
              {repo.stargazers_count > 0 && (
                <span class="flex items-center gap-1 text-xs text-slate-500">
                  <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                  {repo.stargazers_count}
                </span>
              )}
            </div>
            <span class="text-xs text-slate-600 font-mono">{timeAgo(repo.updated_at)}</span>
          </div>
        </a>
      ))}
    </div>
  ) : (
    <div class="text-center py-12 text-slate-600 text-sm font-mono">
      <p>No public repos found — check <a href={`https://github.com/${githubUsername}`} class="text-accent-400 hover:underline">GitHub</a> directly.</p>
    </div>
  )}
</section>
