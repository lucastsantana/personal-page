---
interface Paper {
  title: string;
  journal: string;
  volume: string | null;
  issue: string | null;
  article: string | null;
  year: number;
  authors: string[];
  arxiv: string;
  doi: string | null;
  citations: number;
}
interface Props { publications: Paper[] }
const { publications } = Astro.props;
---

<section id="publications" class="py-24 px-6 max-w-5xl mx-auto">
  <div class="flex items-end justify-between mb-10">
    <h2 class="text-xs font-mono text-accent-400 uppercase tracking-widest">Publications</h2>
    <a
      href="https://inspirehep.net/authors/1669980"
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs text-slate-500 hover:text-slate-300 transition-colors font-mono"
    >
      View all on InspireHEP →
    </a>
  </div>

  <div class="space-y-4">
    {publications.map((paper) => (
      <article class="p-5 rounded-xl bg-slate-900 border border-slate-800 hover:border-slate-700 transition-colors group">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <h3 class="font-medium text-slate-200 group-hover:text-slate-100 transition-colors leading-snug text-sm md:text-base">
              {paper.doi ? (
                <a href={`https://doi.org/${paper.doi}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">
                  {paper.title}
                </a>
              ) : (
                <a href={`https://arxiv.org/abs/${paper.arxiv}`} target="_blank" rel="noopener noreferrer" class="hover:text-accent-400 transition-colors">
                  {paper.title}
                </a>
              )}
            </h3>
            <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">
              {paper.authors.join(', ')}
            </p>
            <div class="flex flex-wrap items-center gap-3 mt-2">
              <span class="text-xs text-slate-400">
                <em>{paper.journal}</em>
                {paper.volume && ` ${paper.volume}`}
                {paper.article && `, ${paper.article}`}
                {` (${paper.year})`}
              </span>
            </div>
          </div>
          <div class="flex flex-col items-end gap-2 shrink-0">
            <span class="font-mono text-xs px-2 py-1 rounded bg-slate-800 text-slate-300 border border-slate-700">
              {paper.citations} cit.
            </span>
            <div class="flex gap-2">
              <a
                href={`https://arxiv.org/abs/${paper.arxiv}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-mono text-slate-500 hover:text-accent-400 transition-colors"
              >
                arXiv:{paper.arxiv}
              </a>
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
